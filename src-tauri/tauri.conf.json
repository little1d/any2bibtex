{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "any2bibtex",
  "version": "0.0.5",
  "identifier": "com.little1d.any2bibtex",
  "build": {
    "beforeDevCommand": "npm run dev:vue",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "any2bibtex",
        "width": 684,
        "height": 640,
        "resizable": false,
        "fullscreen": false,
        "decorations": false,
        "transparent": true,
        "shadow": false,
        "backgroundColor": "#00000000",
        "alwaysOnTop": false,
        "visible": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "nsis", "appimage", "deb"],
    "icon": ["icons/icon.png", "icons/icon.ico"],
    "resources": ["icons/tray-icon.png"],
    "macOS": {
      "signingIdentity": "-"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEIzMjFBREE4RTkyNUIzQQpSV1E2VzVLTzJob3lDeFFLWHNtdFBpVElwMFI2eDlzL3FmUGxJa045YVh1SVY3VVptZ3pCcG44cwo=",
      "endpoints": [
        "https://github.com/little1d/any2bibtex/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
